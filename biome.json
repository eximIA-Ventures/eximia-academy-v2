{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "useSemanticElements": "warn",
        "useFocusableInteractive": "warn",
        "noSvgWithoutTitle": "warn",
        "useButtonType": "warn",
        "noLabelWithoutControl": "warn"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn",
        "noInvalidPositionAtImportRule": "warn"
      },
      "suspicious": {
        "noArrayIndexKey": "warn"
      },
      "complexity": {
        "noForEach": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "files": {
    "ignore": [
      "node_modules",
      ".next",
      "dist",
      ".turbo",
      "supabase",
      "*.gen.ts"
    ]
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded"
    }
  }
}
